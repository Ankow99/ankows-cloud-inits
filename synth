#!/bin/bash
# ---
# se-polymerase (synth.sh)
# Acts as the polymerase to synthesize an isolated, terraform-free LXD 
# reproducer environment using the host's LXD for MAAS + Juju deployments.
# version: 2.0.0
#
# Synthesized by: Pablo Gonzalez De Greiff @ Canonical
# ---

set +e

# Unified unique deployment ID (Can be changed to case number - 8 numbers)
DEPLOY_ID="$(openssl rand -hex 4)"

# Array to hold dynamic LXD Jinja flags
LXC_OPTIONAL_ARGS=()

# Deployment variables
NESTED=false
ACCEPT_DEFAULTS=false
CLEANUP_HANDOVER=false
MAX_WAIT=300 # Maximum wait time in seconds for loops

# --- Colors ---
# Check if stderr is a TTY
if [ -t 2 ]; then
    BRED='\033[1;31m'
    BYELLOW='\033[1;33m'
    NC='\033[0m'
else
    BRED=''
    BYELLOW=''
    NC=''
fi

# ==========================================
# HELPER FUNCTIONS
# ==========================================

show_help() {
    echo -e "$(cat << EOF
${BYELLOW}se-polymerase: LXD Reproducer Synthesis Automation${NC}
Usage: $0 [OPTIONS] <CLOUD_INIT_FILE> [DEPLOY_ID]

Acts as the polymerase to synthesize an isolated, cloud-init based LXD reproducer environment.

${BYELLOW}Options:${NC}
  -h, --help                Show this help message and exit.
  -a, --accept-defaults     Bypass interactive prompts and accept all defaults.
  -n, --nested              Deploy using a nested LXD architecture (default is non-nested).
  -d, --deb                 Use DEB packages for MAAS instead of the default snap.
  -i, --id <launchpad_id>   Import SSH public keys directly from a Launchpad account.

${BYELLOW}Arguments:${NC}
  CLOUD_INIT_FILE           Path to the cloud-init.yaml template to deploy.
  DEPLOY_ID                 Specify a custom alphanumeric deployment ID (max 8 chars).

${BYELLOW}Example:${NC}
  # Synthesize a nested environment accepting all defaults, and use '00426900' as the ID:
  $0 sunbeam/cloud-init.yaml -an 00426900

EOF
    )"
    exit 0
}

emergency_rollback() {
    # If the script dies before the destroy.sh script is created, clean up the host
    if [ "$CLEANUP_HANDOVER" = false ]; then
        
        local rollback_needed=false
        
        # Fast checks for actionable resources
        if [ ${#CREATED_BRIDGES[@]} -gt 0 ] || { [ -n "$VOLATILE_CERT_NAME" ] && [ -f "$CERT_DIR/${VOLATILE_CERT_NAME}.crt" ]; }; then
            rollback_needed=true
        elif [ -n "$LXD_PROJECT" ] && [ "$LXD_PROJECT" != "default" ] && lxc project list 2>/dev/null | grep -q " $LXD_PROJECT "; then
            rollback_needed=true
        fi
        
        # Only sleep and print if there is actual work to do
        if [ "$rollback_needed" = true ]; then
            echo ""
            echo -e "${BRED}Script interrupted! Performing emergency rollback of orphaned resources...${NC}"
            sleep 5
            
            if [ -n "$LXD_PROJECT" ] && [ "$LXD_PROJECT" != "default" ] && lxc project list 2>/dev/null | grep -q " $LXD_PROJECT "; then
                echo "-> Deleting orphaned LXD project: $LXD_PROJECT"
                for inst in $(lxc list --project "$LXD_PROJECT" --format json | jq -r '.[].name'); do
                    lxc stop -f --project "$LXD_PROJECT" "$inst" 2>/dev/null || true
                    lxc delete -f --project "$LXD_PROJECT" "$inst"
                done
                
                for vol in $(lxc storage volume list "$LXD_POOL" --project "$LXD_PROJECT" --format json | jq -r '.[] | select(.type=="custom") | .name'); do
                    lxc storage volume delete "$LXD_POOL" "$vol" --project "$LXD_PROJECT"
                done
                
                for img in $(lxc image list --project "$LXD_PROJECT" --format json | jq -r '.[].fingerprint'); do
                    lxc image delete --project "$LXD_PROJECT" "$img"
                done
                
                lxc project switch default 2>/dev/null
                lxc project delete "$LXD_PROJECT"
            fi
            
            if [ ${#CREATED_BRIDGES[@]} -gt 0 ]; then
                for br in "${CREATED_BRIDGES[@]}"; do
                    echo "-> Deleting orphaned dynamic bridge: $br"
                    lxc network delete "$br"
                done
            fi
            
            if [ -n "$VOLATILE_CERT_NAME" ] && [ -f "$CERT_DIR/${VOLATILE_CERT_NAME}.crt" ]; then
                echo "-> Cleaning up orphaned certificates..."
                FINGERPRINT=$(lxc config trust list --format json | jq -r ".[] | select(.name==\"${VOLATILE_CERT_NAME}\") | .fingerprint")
                if [ -n "$FINGERPRINT" ] && [ "$FINGERPRINT" != "null" ]; then
                    lxc config trust remove "$FINGERPRINT"
                fi
                rm -f "$CERT_DIR/${VOLATILE_CERT_NAME}.crt" "$CERT_DIR/${VOLATILE_CERT_NAME}.key"
            fi
        fi
        
        # Prevent double-execution if multiple exit signals are caught
        CLEANUP_HANDOVER=true 
    fi
}

get_default() {
    grep -E "^\s*\{\%\s*set\s+custom_$1\s*=" "$CLOUD_INIT" | sed -E 's/.*=[[:space:]]*//; s/[[:space:]]*%\}.*//; s/^"//; s/"$//'
}

extract_num() {
    local val
    val=$(echo "$1" | sed -E 's/[^0-9]//g')
    echo "${val:-0}" # Safely fallback to 0 if empty
}

pause_to_continue() {
    local prompt_msg="$1"
    
    # Auto-continue if -a flag was passed
    if [ "$ACCEPT_DEFAULTS" = true ]; then
        return 0
    fi
    
    echo -ne "${prompt_msg} "
    read -r </dev/tty
}

confirm_or_abort() {
    local prompt_msg="$1"

    # Auto-confirm if -a flag was passed
    if [ "$ACCEPT_DEFAULTS" = true ]; then
        return 0
    fi

    echo -ne "${prompt_msg} [y/N]: "
    read -r confirm_input </dev/tty
    if [[ ! "$confirm_input" =~ ^[Yy]$ ]]; then
        echo ""
        echo -e "${BRED}Action aborted by user. Exiting.${NC}"
        exit 1
    fi
}

# Prompt Helper Function - ask_var "Prompt Text" "jinja_var_name"
ask_var() {
    local prompt_text="$1"
    local config_key="$2"
    local default_val=""
    local user_input
    local bash_var_name
    
    # Extract default value from Jinja cloud-init template
    if [ -n "$config_key" ] && [ -f "$CLOUD_INIT" ]; then
        default_val=$(get_default "$config_key")
    fi
    
    # Prompt for value if accept defaults is false
    if [ "$ACCEPT_DEFAULTS" = true ]; then
        user_input="$default_val"
    else
        echo -ne "  ${BYELLOW}${prompt_text} [${NC}${default_val}${BYELLOW}]: ${NC}"
        read -r user_input </dev/tty
        user_input="${user_input:-$default_val}"
    fi
    
    # Smart GiB appending
    if [[ "$default_val" == *"GiB" ]] && [[ "$user_input" =~ ^[0-9]+$ ]]; then
        user_input="${user_input}GiB"
    fi
    
    # Export to LXC args if a config key exists and export as uppercase bash variable
    if [ -n "$config_key" ]; then
        LXC_OPTIONAL_ARGS+=("-c" "user.${config_key}=${user_input}")
        
        bash_var_name=$(echo "$config_key" | tr '[:lower:]' '[:upper:]')
        export "$bash_var_name"="$user_input"
    fi
}

# Dynamic 3-Path Bridge Generator - create_dynamic_bridge "Prompt Text" "jinja_bridge_name" "dhcp_on/off" "CIDR"
create_dynamic_bridge() {
    local prompt_text="$1"
    local var_key="$2"
    local dhcp_flag="$3"
    local cidr_var="$4"
    
    # Strip 'os_' prefix if it exists, grab 1st letter
    local clean_name="${var_key#os_}"
    local default_br="${clean_name:0:1}br-${DEPLOY_ID}"
    
    local bridge_name
    local bridge_cidr
    local auto_ip
    local default_cidr
    local user_cidr
    local current_dhcp
    local current_nat

    # Setup our loop control variable
    local valid_bridge=false

    # Keep prompting until a valid bridge is selected or created
    while [ "$valid_bridge" = false ]; do
    
        # Prompt for value if accept defaults is false
        if [ "$ACCEPT_DEFAULTS" = true ]; then
            bridge_name="$default_br"
        else
            echo -ne "  ${BYELLOW}${prompt_text} [${NC}${default_br}${BYELLOW}]: ${NC}"
            read -r user_input </dev/tty
            bridge_name="${user_input:-$default_br}"
        fi
        
        # 3-Path CIDR Logic
        if lxc network show "$bridge_name" >/dev/null 2>&1; then
            
            # Using existing bridge, obtain CIDR
            echo -e "    ${BYELLOW}Bridge '${NC}${bridge_name}${BYELLOW}' already exists. Fetching CIDR and checking configuration...${NC}"
            
            # Check DHCP flag
            current_dhcp=$(lxc network get "$bridge_name" ipv4.dhcp 2>/dev/null)
            current_dhcp="${current_dhcp:-true}" # LXD defaults to true if unset
            
            if [ "$current_dhcp" != "$dhcp_flag" ]; then
                echo ""
                echo -e "${BRED}Error: Existing bridge '${NC}${bridge_name}${BRED}' has 'ipv4.dhcp=${NC}${current_dhcp}${BRED}', but this network requires 'ipv4.dhcp=${NC}${dhcp_flag}${BRED}'!${NC}"
                echo -e "Please specify a different bridge name or delete the conflicting bridge."
                echo ""
                if [ "$ACCEPT_DEFAULTS" = true ]; then
                    exit 1
                else
                    continue
                fi
            fi
            
            # Check NAT flag
            current_nat=$(lxc network get "$bridge_name" ipv4.nat 2>/dev/null)
            current_nat="${current_nat:-false}" # Assume false if strictly unset
            
            if [ "$current_nat" != "true" ]; then
                echo ""
                echo -e "${BRED}Error: Existing bridge '${NC}${bridge_name}${BRED}' has 'ipv4.nat=${NC}${current_nat}${BRED}', but this network requires 'ipv4.nat=${NC}true${BRED}' for outbound internet!${NC}"
                echo -e "Please specify a different bridge name or enable NAT on this bridge."
                echo ""
                if [ "$ACCEPT_DEFAULTS" = true ]; then
                    exit 1
                else
                    continue
                fi
            fi
            
            auto_ip=$(lxc network get "$bridge_name" ipv4.address)
            bridge_cidr=$(echo "$auto_ip" | awk -F'[/.]' '{print $1"."$2"."$3".0/"$5}')
            
            if [ "$ACCEPT_DEFAULTS" = false ]; then
                echo -e "  ${BYELLOW}${prompt_text% Name} fetched CIDR: ${NC}${bridge_cidr}"
            fi
            
            valid_bridge=true
            
        elif [ "$bridge_name" = "$default_br" ]; then
            
            # Using random bridge, create it and obtain CIDR
            echo ""
            confirm_or_abort "Create new random ${prompt_text% Name} '$bridge_name' to auto-assign CIDR?"
            
            echo "Creating random managed '$bridge_name' (DHCP=${dhcp_flag})..."
            if ! lxc network create "$bridge_name" \
              ipv4.nat=true \
              ipv4.dhcp="$dhcp_flag" \
              ipv6.address=none; then
                echo ""
                echo -e "${BRED}Error: Failed to create random ${prompt_text% Name} '${NC}$bridge_name${BRED}'. Please try again...${NC}"
                echo ""
                if [ "$ACCEPT_DEFAULTS" = true ]; then
                    exit 1
                else
                    continue
                fi
            fi
            
            lxc network set "$bridge_name" --property description="${PRETTY_REPRO} ${prompt_text% Name} ($DEPLOY_ID)"
            CREATED_BRIDGES+=("$bridge_name")
            
            auto_ip=$(lxc network get "$bridge_name" ipv4.address)
            bridge_cidr=$(echo "$auto_ip" | awk -F'[/.]' '{print $1"."$2"."$3".0/"$5}')
            echo ""
            if [ "$ACCEPT_DEFAULTS" = false ]; then
                echo -e "  ${BYELLOW}${prompt_text% Name} Auto-Assigned CIDR: ${NC}${bridge_cidr}"
            fi
            
            valid_bridge=true
            
        else
            
            # Creating new bridge, ask for CIDR
            echo -e "    ${BYELLOW}Bridge '${NC}${bridge_name}${BYELLOW}' doesn't exist. Asking for new CIDR...${NC}"
            
            default_cidr=$(get_default "$cidr_var")
            [ -z "$default_cidr" ] && default_cidr="10.0.0.0/22"
            
            echo -ne "  ${BYELLOW}${prompt_text% Name} CIDR [${NC}${default_cidr}${BYELLOW}]: ${NC}"
            read -r user_cidr </dev/tty
            bridge_cidr="${user_cidr:-$default_cidr}"
            
            echo ""
            confirm_or_abort "Create custom managed ${prompt_text% Name} '$bridge_name' ($bridge_cidr)?"
            
            echo "Creating custom managed '$bridge_name' ($bridge_cidr DHCP=${dhcp_flag})..."
            read -r gw_ip prefix <<< "$(python3 -c "
import ipaddress, sys
try:
    net = ipaddress.IPv4Network('$bridge_cidr', strict=False)
    print(f'{list(net.hosts())[0]} {net.prefixlen}')
except Exception:
    print('ERROR')
")"
            if [ "$gw_ip" = "ERROR" ] || [ -z "$gw_ip" ]; then
                echo ""
                echo -e "${BRED}Error: Invalid CIDR format '${NC}${bridge_cidr}${BRED}' provided for bridge '${NC}$bridge_name${BRED}'. Please try again...${NC}"
                echo ""
                continue
            fi
            
            if ! lxc network create "$bridge_name" \
              ipv4.address="${gw_ip}/${prefix}" \
              ipv4.nat=true \
              ipv4.dhcp="$dhcp_flag" \
              ipv6.address=none; then
                echo ""
                echo -e "${BRED}Error: Failed to create custom ${prompt_text% Name} '${NC}$bridge_name${BRED}'. Please try again...${NC}"
                echo ""
                continue
            fi
            lxc network set "$bridge_name" --property description="${PRETTY_REPRO} ${prompt_text% Name} ($DEPLOY_ID)"
            CREATED_BRIDGES+=("$bridge_name")
            echo ""

            valid_bridge=true
        fi
    done
    
    # Export Bridge Name into LXC args and bash env
    LXC_OPTIONAL_ARGS+=("-c" "user.${var_key}=${bridge_name}")
    export "$(echo "$var_key" | tr '[:lower:]' '[:upper:]')"="$bridge_name"

    # Export CIDR into LXC args and bash env
    LXC_OPTIONAL_ARGS+=("-c" "user.${cidr_var}=${bridge_cidr}")
    export "$(echo "$cidr_var" | tr '[:lower:]' '[:upper:]')"="$bridge_cidr"
    
    # Track Primary Bridge Gateway for Netplan injection later
    if [ -z "$PRIMARY_BRIDGE" ]; then
        read -r gw mask stat <<< "$(python3 -c "
import ipaddress, sys
try:
    net = ipaddress.IPv4Network('$bridge_cidr', strict=False)
    hosts = list(net.hosts())
    print(f'{hosts[0]} {net.prefixlen} {hosts[1]}')
except Exception:
    print('ERROR')
")"
        if [ "$gw" = "ERROR" ] || [ -z "$gw" ]; then
            echo ""
            echo -e "${BRED}Error: Could not calculate Primary VM network properties from CIDR '${NC}$bridge_name${BRED}'. Exiting.${NC}"
            exit 1
        fi
        PRIMARY_BRIDGE="$bridge_name"
        PRIMARY_GW_IP="$gw"
        PRIMARY_MASK="$mask"
        PRIMARY_STATIC_IP="$stat"
    fi
}

# ==========================================
# INITIAL DEPENDENCY CHECK
# ==========================================

# Check for dependencies
for cmd in jq openssl python3 lxc; do
    if ! command -v "$cmd" &> /dev/null; then
        echo ""
        echo -e "${BRED}Error: '${NC}${cmd}${BRED}' is not installed. Please install it.${NC}"
        exit 1
    fi
done

# Check for LXD initialization
if ! lxc storage list --format json | jq -e 'length > 0' > /dev/null 2>&1; then
    echo ""
    echo -e "${BYELLOW}-> LXD appears uninitialized. Running auto-initialization...${NC}"
    
    # Auto-initialize with default loop-backed storage and default network
    if ! lxd init --auto; then
        echo ""
        echo -e "${BRED}Error: Failed to auto-initialize LXD. Please run '${NC}lxd init --auto${BRED}' manually and try again.${NC}"
        exit 1
    fi
    echo -e "  Configuring LXD to listen on port 8443..."
    lxc config set core.https_address ":8443"
    echo ""
    echo -e "  LXD initialized successfully."
else
    # Ensure it is listening on 8443 even if it was previously initialized
    CURRENT_ADDR=$(lxc config get core.https_address)
    
    # Check if it's either empty OR doesn't end in :8443
    if [[ "$CURRENT_ADDR" != *":8443" ]]; then
        echo ""
        if [ -z "$CURRENT_ADDR" ]; then
            echo -e "${BYELLOW}-> LXD is not listening on the network. Configuring to port 8443...${NC}"
        else
            echo -e "${BYELLOW}-> LXD is listening on '${NC}${CURRENT_ADDR}${BYELLOW}' instead of port 8443. Reconfiguring...${NC}"
        fi
        
        # Override to listen on all interfaces on port 8443
        lxc config set core.https_address ":8443"
    fi
fi

# ==========================================
# FUNCTION PARAMETERS
# ==========================================

# Split combined short flags (e.g. -nd -> -n -d)
parsed_args=()
for arg in "$@"; do
    if [[ "$arg" =~ ^-[a-zA-Z]{2,}$ ]]; then
        for (( i=1; i<${#arg}; i++ )); do
            parsed_args+=("-${arg:$i:1}")
        done
    else
        parsed_args+=("$arg")
    fi
done
set -- "${parsed_args[@]}"

# --- Argument Parsing ---
echo ""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            ;;
        -a|--accept-defaults)
            echo -e "${BYELLOW}-> Accepting all default template values${NC}"
            echo ""
            ACCEPT_DEFAULTS=true
            shift 1
            ;;
        -n|--nested)
            NESTED=true
            shift 1
            ;;
        -d|--deb)
            echo -e "${BYELLOW}-> Using deb MAAS packages instead of snap${NC}"
            echo ""
            LXC_OPTIONAL_ARGS+=("-c" "user.maas_snap=false")
            shift 1
            ;;
        -i|--id)
            echo -e "${BYELLOW}-> Importing SSH keys from Launchpad:${NC} lp:$2"
            echo ""
            LXC_OPTIONAL_ARGS+=("-c" "user.ssh_import_id=lp:$2")
            shift 2
            ;;
        -*)
            echo -e "${BRED}Error: Unknown flag '${NC}${1}${BRED}'${NC}"
            exit 1
            ;;
        *)
            # Catch all non-flag arguments (File path and Deploy ID)
            POSITIONAL_ARGS+=("$1")
            shift 1
            ;;
    esac
done

# Nested architecture toggle
if [ "$NESTED" = false ]; then
    echo -e "${BYELLOW}-> Using default non-nested LXD architecture.${NC}"
    echo ""
    LXC_OPTIONAL_ARGS+=("-c" "user.nested_lxd=false")
else
    echo -e "${BYELLOW}-> Using nested LXD architecture${NC} - ${BRED}WARNING: DEGRADED PERFORMANCE IF NOT RUNNING IN BARE METAL${NC}"
    echo ""
    LXC_OPTIONAL_ARGS+=("-c" "user.nested_lxd=true")
fi

# ==========================================
# POSITIONAL ARGUMENT RESOLUTION
# ==========================================

# Resolve the Cloud-Init Payload File
if [ ${#POSITIONAL_ARGS[@]} -lt 1 ]; then
    echo -e "${BRED}Error: You must provide the path to a cloud-init template.${NC}"
    echo "Usage: $0 [OPTIONS] <CLOUD_INIT_FILE> [DEPLOY_ID]"
    exit 1
fi

CLOUD_INIT_FILE="${POSITIONAL_ARGS[0]}"

if [ ! -f "$CLOUD_INIT_FILE" ]; then
    echo -e "${BRED}Error: Payload file '${NC}${CLOUD_INIT_FILE}${BRED}' not found!${NC}"
    exit 1
fi

# Dynamically set directories based on the resolved absolute path of the file
CLOUD_INIT="$(realpath "$CLOUD_INIT_FILE")"
SCRIPT_DIR="$(dirname "$CLOUD_INIT")"
CERT_DIR="$SCRIPT_DIR/.certs"

# Resolve the Deploy ID Overwrite (If provided)
if [ ${#POSITIONAL_ARGS[@]} -ge 2 ]; then
    # Directly override and lowercase the default Deploy ID
    DEPLOY_ID=$(echo "${POSITIONAL_ARGS[1]}" | tr '[:upper:]' '[:lower:]')
fi

# Verify deploy ID
if [[ ! "$DEPLOY_ID" =~ ^[a-z0-9]{1,8}$ ]]; then
    echo -e "${BRED}Error: Invalid Deployment ID '${NC}${DEPLOY_ID}${BRED}'${NC}"
    echo "The Deployment ID must be between 1 and 8 lowercase letters and/or numbers (no dashes)."
    exit 1
fi

# Smart SSH Key Detection
if [ -f ~/.ssh/id_ed25519 ]; then
    SSH_ID=~/.ssh/id_ed25519
elif [ -f ~/.ssh/id_rsa ]; then
    SSH_ID=~/.ssh/id_rsa
else
    # Only prompt for a local key if no Launchpad ID was provided
    if [[ ! " ${LXC_OPTIONAL_ARGS[*]} " == *"user.ssh_import_id"* ]]; then
        echo -ne "No SSH identity found, please insert path to one: "
        read -r user_input </dev/tty
        
        # Safely expand tilde (~) to $HOME if the user typed it
        user_input="${user_input/#\~/$HOME}"
        SSH_ID="$user_input"
    fi
fi

# Auto-inject local SSH public key
if [ -f "${SSH_ID}.pub" ]; then
    echo -e "${BYELLOW}-> Auto-injecting local SSH public key:${NC} ${SSH_ID}.pub"
    echo ""
    PUB_KEY=$(cat "${SSH_ID}.pub")
    LXC_OPTIONAL_ARGS+=("-c" "user.ssh_key=$PUB_KEY")
fi

# Abort if there's neither a local key nor a Launchpad ID
if [[ ! " ${LXC_OPTIONAL_ARGS[*]} " == *"user.ssh_key"* ]] && [[ ! " ${LXC_OPTIONAL_ARGS[*]} " == *"user.ssh_import_id"* ]]; then
    echo -e "${BRED}Error: No SSH keys found (${NC}${SSH_ID}.pub${BRED}) and no Launchpad ID provided! Aborting.${NC}"
    exit 1
fi

# Catch normal exits and crashes
trap emergency_rollback EXIT

# Catch Ctrl+C (INT) and Kill (TERM), run the rollback check, and FORCE an exit
trap 'emergency_rollback; exit 1' INT TERM

# ==========================================
# INTERACTIVE VARIABLE COLLECTION
# ==========================================

REPRO_NAME=$(get_default "repro_name")
PRETTY_REPRO=$(echo "$REPRO_NAME" | awk '{print toupper(substr($0,1,1))substr($0,2)}')
VM_NAME=$(get_default "vm_name")
IMAGE=$(get_default "vm_image")

# Generate the random resources using the specific prefix + unified ID (8 hex chars)
VOLATILE_CERT_NAME="${REPRO_NAME}-cert-${DEPLOY_ID}"
MUX_SOCKET="/tmp/${REPRO_NAME}-ssh-${DEPLOY_ID}.sock"

# Juju status trigger message
JUJU_TRIGGER_MSG=$(get_default "juju_trigger")

if [ "$ACCEPT_DEFAULTS" = false ]; then
    echo -e "${BYELLOW}-> -------- Dynamic ${PRETTY_REPRO} Payload Configuration ---------${NC}"
    echo ""
fi

# Prompt for the host's unique LXD Project Name
DEFAULT_PROJECT="${REPRO_NAME}-${DEPLOY_ID}"

if [ "$ACCEPT_DEFAULTS" = true ]; then
    LXD_PROJECT="$DEFAULT_PROJECT"
else
    echo -ne "  ${BYELLOW}Host LXD Project Name [${NC}${DEFAULT_PROJECT}${BYELLOW}]: ${NC}"
    read -r user_input </dev/tty
    LXD_PROJECT="${user_input:-$DEFAULT_PROJECT}"
fi

# Inject project name only if non-nested
if [ "$NESTED" = false ]; then
    LXC_OPTIONAL_ARGS+=("-c" "user.lxd_project=$LXD_PROJECT")
fi

CREATED_BRIDGES=()
PRIMARY_BRIDGE=""

# Scan cloud-init for any Jinja variable that has a PROMPT: tag
while read -r line; do
    # 1. Extract prompt string (everything after PROMPT:)
    PROMPT_MSG=$(echo "$line" | sed -n 's/.*PROMPT:\([^[]*\).*/\1/p' | xargs)
    
    # 2. Extract the Jinja config key
    VAR_KEY=$(echo "$line" | sed -E 's/.*set custom_([a-zA-Z0-9_]+).*/\1/')
    
    # 3. Ask for variable interactively and create bridge if needed
    if [[ "$line" == *"[BRIDGE:"* ]]; then
        DHCP_VAL=$(echo "$line" | grep -oP 'dhcp=\K[a-z]+')
        CIDR_VAR=$(echo "$line" | grep -oP 'cidr=\K[a-zA-Z0-9_]+')
        
        if [ "$NESTED" = false ]; then
            create_dynamic_bridge "$PROMPT_MSG" "$VAR_KEY" "$DHCP_VAL" "$CIDR_VAR"
        fi
    else
        ask_var "$PROMPT_MSG" "$VAR_KEY"
    fi
    
done < <(grep -E '\{\%\s*set\s+custom_.*PROMPT:' "$CLOUD_INIT")

# If Nested, prompt for the single Host Uplink right after parsing the Jinja payload
if [ "$NESTED" = true ]; then
    create_dynamic_bridge "Nested Host Uplink" "host_bridge" "true" "host_cidr"
fi

# ==========================================
# DYNAMIC RESOURCE CALCULATION
# ==========================================

# Format: [prefix]_[type] (e.g., cloud_osd_disk)
#   - type: Must be 'cpu', 'ram', or 'disk'.
#   - prefix: Used to hunt down matching multipliers like [prefix]_count and [prefix]_ha.

TOT_CPU=0
TOT_RAM=0
TOT_DISK=0
UNIQUE_PREFIXES=""

# Scan for any variable ending in _cpu, _ram, or _disk
while read -r line; do
    var_key=$(echo "$line" | sed -E 's/.*set custom_([a-zA-Z0-9_]+).*/\1/')
    
    # 1. Discovery phase, scan cloud-init for any variable ending in _cpu, _ram, or _disk
    if [[ "$var_key" =~ ^(.*)_(cpu|ram|disk)$ ]]; then
        prefix="${BASH_REMATCH[1]}"
        res_type="${BASH_REMATCH[2]}"

        UNIQUE_PREFIXES+=" $prefix "
        
        # 2. Extract base value, get the raw number (stripping 'GiB' or 'GB' safely)
        bash_var=$(echo "$var_key" | tr '[:lower:]' '[:upper:]')
        val="${!bash_var}"
        [ -z "$val" ] && val=$(get_default "$var_key")
        num=$(extract_num "$val")
        [ -z "$num" ] && num=0
        
        # 3. Calculate multipliers, how many times does this resource exist?
        total_mult=1
        search_prefix="$prefix"
        
        # 3a. Check for a specific internal multiplier (e.g., [prefix]_count)
        count_var="${prefix}_count"
        bash_count=$(echo "$count_var" | tr '[:lower:]' '[:upper:]')
        c_val="${!bash_count}"
        [ -z "$c_val" ] && c_val=$(get_default "$count_var")
        [ -n "$c_val" ] && total_mult=$(( total_mult * $(extract_num "$c_val") ))
        
        # 3b. Check for HA multiplier by traversing up the prefix tree
        while [ -n "$search_prefix" ]; do
            ha_var="${search_prefix}_ha"
            bash_ha=$(echo "$ha_var" | tr '[:lower:]' '[:upper:]')
            m_val="${!bash_ha}"
            [ -z "$m_val" ] && m_val=$(get_default "$ha_var")
            
            if [ -n "$m_val" ]; then
                total_mult=$(( total_mult * $(extract_num "$m_val") ))
                break
            fi
            
            # Chop off the last segment of the prefix by "_"
            if [[ "$search_prefix" == *"_"* ]]; then
                search_prefix="${search_prefix%_*}"
            else
                break
            fi
        done
        
        # 4. Add (Base Value * Total Multiplier) to the global buckets
        if [ "$res_type" == "cpu" ]; then
            TOT_CPU=$(( TOT_CPU + (num * total_mult) ))
        elif [ "$res_type" == "ram" ]; then
            TOT_RAM=$(( TOT_RAM + (num * total_mult) ))
        elif [ "$res_type" == "disk" ]; then
            TOT_DISK=$(( TOT_DISK + (num * total_mult) ))
        fi
    fi
done < <(grep -E '\{\%\s*set\s+custom_.*_(cpu|ram|disk)\s*=' "$CLOUD_INIT")

# Find primary VM resources - primary -> maas -> jinja_defaults -> fallback
P_CPU="${PRIMARY_CPU:-${MAAS_CPU:-$(get_default maas_cpu)}}"
P_RAM="${PRIMARY_RAM:-${MAAS_RAM:-$(get_default maas_ram)}}"
P_DISK="${PRIMARY_DISK:-${MAAS_DISK:-$(get_default maas_disk)}}"

# Extract numeric values for the limits
P_RAM_NUM=$(extract_num "$P_RAM")
P_DISK_NUM=$(extract_num "$P_DISK")

# Primary VM Constraints
if [ "$NESTED" = false ]; then
    # In non-nested, the primary VM is just the MAAS server.
    CPU_LIMIT="${P_CPU:-4}"
    RAM_LIMIT="${P_RAM_NUM:-8}GiB"
    DISK_LIMIT="${P_DISK_NUM:-30}GiB"
else
    # In Nested, the primary VM must hold MAAS + all nested nodes.
    CPU_LIMIT="$TOT_CPU"
    RAM_LIMIT="${TOT_RAM}GiB"
    DISK_LIMIT="${TOT_DISK}GiB"
fi

# ==========================================
# FINAL RESOURCE CONFIRMATION
# ==========================================

# Fetch Host Resources
HOST_CPU=$(nproc 2>/dev/null || echo 0)
# Convert Kb to GiB and round to nearest whole number
HOST_RAM=$(awk '/MemTotal/ {printf "%.0f", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo 0)

# Evaluate Constraints
WARNINGS=""
DANGER=false

if [ "$HOST_CPU" -gt 0 ] && [ "$TOT_CPU" -gt "$HOST_CPU" ]; then
    WARNINGS+="${BYELLOW}  ! CPU OVERCOMMIT: Requested ${TOT_CPU} cores, but host only has ${HOST_CPU} cores.${NC}\n"
fi

if [ "$HOST_RAM" -gt 0 ] && [ "$TOT_RAM" -gt "$HOST_RAM" ]; then
    WARNINGS+="${BRED}  ! RAM EXHAUSTION: Requested ${TOT_RAM} GiB, but host only has ${HOST_RAM} GiB total!${NC}\n"
    DANGER=true
fi

echo ""
echo -e "${BYELLOW}-> -------------- Deployment Summary --------------${NC}"
echo ""
printf "  %-28s %s\n" "Project Name:" "$LXD_PROJECT"

# Network Summary
if [ "$NESTED" = true ]; then
    printf "  %-28s %s\n" "Architecture:" "nested (using own LXD inside VM)"
    echo -e "${BYELLOW}  -------------------- Network --------------------${NC}"
    printf "  %-28s %s\n" "Uplink Bridge:" "$PRIMARY_BRIDGE (Gateway: $PRIMARY_GW_IP)"
    printf "  %-30s %s\n" "  - Subnet CIDR:" "$HOST_CIDR"
else
    printf "  %-28s %s\n" "Architecture:" "non-nested (using host's bare-metal LXD)"
    echo -e "${BYELLOW}  -------------------- Network --------------------${NC}"
    printf "  %-28s %s\n" "Primary Uplink:" "$PRIMARY_BRIDGE (Gateway: $PRIMARY_GW_IP)"
    
    # Loop over cloud-init to find defined bridges and their original prompt text
    while read -r line; do
        PROMPT_MSG=$(echo "$line" | sed -n 's/.*PROMPT:\([^[]*\).*/\1/p' | xargs)
        VAR_KEY=$(echo "$line" | sed -E 's/.*set custom_([a-zA-Z0-9_]+).*/\1/')
        CIDR_VAR=$(echo "$line" | grep -oP 'cidr=\K[a-zA-Z0-9_]+')
        
        # Map back to the Bash exported variables
        BASH_BR_VAR=$(echo "$VAR_KEY" | tr '[:lower:]' '[:upper:]')
        BASH_CIDR_VAR=$(echo "$CIDR_VAR" | tr '[:lower:]' '[:upper:]')
        
        BR_VAL="${!BASH_BR_VAR}"
        CIDR_VAL="${!BASH_CIDR_VAR}"
        
        if [ -n "$BR_VAL" ]; then
            printf "  %-28s %s\n" "${PROMPT_MSG}:" "$BR_VAL"
            printf "  %-30s %s\n" "  - Subnet CIDR:" "$CIDR_VAL"
            
            # Dynamically fetch matching IP counts based on the prefix (e.g., MAAS_ or OS_)
            BR_PREFIX=$(echo "$BASH_BR_VAR" | cut -d'_' -f1) 
            for ip_var in $(compgen -v | grep "^${BR_PREFIX}_.*IP_COUNT$"); do
                # Clean up the name for display and force 'API' capitalization\
                clean_name=$(echo "$ip_var" | sed "s/^${BR_PREFIX}_//" | sed 's/_*IP_COUNT$//' | tr '[:upper:]' '[:lower:]' | tr '_' ' ' | awk '{for(i=1;i<=NF;i++)sub(/./,toupper(substr($i,1,1)),$i)}1' | sed 's/Api/API/g')
                if [ -z "$clean_name" ]; then clean_name="Reserved"; fi
                
                ip_val="${!ip_var}"
                printf "  %-30s %s\n" "  - $clean_name IPs:" "$ip_val"
            done
        fi
    done < <(grep -E '.*\[BRIDGE:' "$CLOUD_INIT")
fi

# Node Allocation Summary
echo -e "${BYELLOW}  ---------------- Node Allocation ----------------${NC}"

for pref in $(echo "$UNIQUE_PREFIXES" | tr ' ' '\n' | sort -u | grep -v '^$'); do
    bash_cpu=$(echo "${pref}_cpu" | tr '[:lower:]' '[:upper:]')
    cpu_val="${!bash_cpu:-$(get_default "${pref}_cpu")}"
    
    if [ -n "$cpu_val" ]; then
        bash_ram=$(echo "${pref}_ram" | tr '[:lower:]' '[:upper:]')
        ram_val="${!bash_ram:-$(get_default "${pref}_ram")}"
        
        bash_disk=$(echo "${pref}_disk" | tr '[:lower:]' '[:upper:]')
        disk_val="${!bash_disk:-$(get_default "${pref}_disk")}"
        
        bash_ha=$(echo "${pref}_ha" | tr '[:lower:]' '[:upper:]')
        ha_val="${!bash_ha:-$(get_default "${pref}_ha")}"
        [ -z "$ha_val" ] && ha_val=1
        
        # Fetch the EXACT first word of the CPU prompt for perfect capitalization (e.g., "MAAS", "Juju")
        pretty_name=$(grep -E "^\s*\{\%\s*set\s+custom_${pref}_cpu\s*=" "$CLOUD_INIT" | sed -n 's/.*PROMPT:\([^ ]*\).*/\1/p')
        
        # Fallback to title-case if no prompt is found
        if [ -z "$pretty_name" ]; then
            pretty_name=$(echo "$pref" | tr '_' ' ' | awk '{for(i=1;i<=NF;i++)sub(/./,toupper(substr($i,1,1)),$i)}1')
        fi

        # Dynamic Child Resource Append (e.g. OSDs)
        extra_disks=""
        for sub_pref in $(echo "$UNIQUE_PREFIXES" | tr ' ' '\n' | sort -u | grep -v '^$'); do
            # If it's a child of the current prefix (e.g. cloud_osd is a child of cloud)
            if [[ "$sub_pref" == "${pref}_"* ]]; then
                sub_cpu_var=$(echo "${sub_pref}_cpu" | tr '[:lower:]' '[:upper:]')
                sub_cpu="${!sub_cpu_var:-$(get_default "${sub_pref}_cpu")}"
                
                # If it has NO CPU, it's an attached resource, not a standalone node
                if [ -z "$sub_cpu" ]; then
                    sub_disk_var=$(echo "${sub_pref}_disk" | tr '[:lower:]' '[:upper:]')
                    sub_disk="${!sub_disk_var:-$(get_default "${sub_pref}_disk")}"
                    
                    sub_count_var=$(echo "${sub_pref}_count" | tr '[:lower:]' '[:upper:]')
                    sub_count="${!sub_count_var:-$(get_default "${sub_pref}_count")}"
                    
                    if [ -n "$sub_disk" ] && [ -n "$sub_count" ]; then
                        # Format nicely: cloud_osd -> OSD
                        sub_name=$(echo "${sub_pref}" | sed "s/^${pref}_//" | tr '[:lower:]' '[:upper:]')
                        extra_disks+=" + ${sub_count}x ${sub_disk} ${sub_name}s"
                    fi
                fi
            fi
        done
        
        left_col="${ha_val}x ${pretty_name} Node(s):"
        right_col="${cpu_val} cores, ${ram_val} RAM, ${disk_val} Disk${extra_disks} (each)"
        printf "  %-28s %s\n" "$left_col" "$right_col"
    fi
done

# Constraints Summary
echo -e "${BYELLOW}  ------------- Capacity & Constraints ------------${NC}"
printf "  %-28s %s\n" "Primary VM Size:" "${CPU_LIMIT} cores, ${RAM_LIMIT} RAM, ${DISK_LIMIT} Disk"
printf "  %-28s %s\n" "Total Footprint:" "${TOT_CPU} cores, ${TOT_RAM}GiB RAM, ${TOT_DISK}GiB Disk"
echo ""

if [ -n "$WARNINGS" ]; then
    echo -e "${BRED}-> --------------- RESOURCE WARNINGS --------------${NC}"
    echo -e "$WARNINGS"
fi

if [ "$DANGER" = true ]; then
    ORIG_ACCEPT="$ACCEPT_DEFAULTS"
    ACCEPT_DEFAULTS=false
    confirm_or_abort "${BRED}Host lacks sufficient RAM. Force proceed anyway?${NC}"
    ACCEPT_DEFAULTS="$ORIG_ACCEPT"
else
    confirm_or_abort "Proceed with deployment using these resources and networks?"
fi

# ==========================================
# NETWORK CONFIGURATION
# ==========================================

# Non-nested static IP network configuration
if [ "$NESTED" = false ]; then
    
    # Generate and Trust Volatile LXD Certificate
    echo ""
    echo -e "${BYELLOW}-> Generating volatile LXD certificate:${NC} ${CERT_DIR}/${VOLATILE_CERT_NAME}"
    
    mkdir -p "$CERT_DIR"
    CLIENT_CRT="$CERT_DIR/${VOLATILE_CERT_NAME}.crt"
    CLIENT_KEY="$CERT_DIR/${VOLATILE_CERT_NAME}.key"
    
    # Generate the cert pair silently
    openssl req -x509 -newkey rsa:2048 -keyout "$CLIENT_KEY" -out "$CLIENT_CRT" -nodes -days 30 -subj "/CN=${VOLATILE_CERT_NAME}" 2>/dev/null
    
    # Trust the cert in the Host's LXD daemon
    lxc config trust add "$CLIENT_CRT" --name "$VOLATILE_CERT_NAME"
    
    # Read contents and base64 encode to safely inject via LXD config
    CRT_B64=$(base64 -w0 "$CLIENT_CRT")
    KEY_B64=$(base64 -w0 "$CLIENT_KEY")
    
    LXC_OPTIONAL_ARGS+=("-c" "user.lxd_cert_b64=$CRT_B64")
    LXC_OPTIONAL_ARGS+=("-c" "user.lxd_key_b64=$KEY_B64")
    
    # Configure Static IP using the dynamically calculated PRIMARY gateway
    [[ -z "$TLD" ]] && TLD="maas"
    [[ -z "$MAAS_DNS" ]] && MAAS_DNS="8.8.8.8"
    
    # Set netplan config with static IP, non DHCP and MAAS DNS server
    read -r -d '' STATIC_NET <<EOF
network:
  version: 2
  ethernets:
    enp5s0:
      dhcp4: false
      addresses: [${PRIMARY_STATIC_IP}/${PRIMARY_MASK}]
      routes:
        - to: default
          via: $PRIMARY_GW_IP
      nameservers:
        addresses: [${PRIMARY_STATIC_IP}, ${MAAS_DNS}]
        search: [${TLD}, maas]
EOF
    
    # Inject static net config and 
    LXC_OPTIONAL_ARGS+=("-c" "cloud-init.network-config=$STATIC_NET")
fi

# Attach to primary bridge
LXC_OPTIONAL_ARGS+=("-n" "$PRIMARY_BRIDGE")

# ==========================================
# CREATE LXD PROJECT
# ==========================================

# Create LXD Project
if [ "$LXD_PROJECT" != "default" ]; then
    if ! lxc project list | grep -q " $LXD_PROJECT "; then
        echo ""
        echo -e "${BYELLOW}-> Creating Host LXD Project:${NC} $LXD_PROJECT"
        echo ""
        confirm_or_abort "Create custom LXD project '$LXD_PROJECT'?"
        
        # Create project with isolated images and profiles, but shared networks
        lxc project create "$LXD_PROJECT" -c features.images=true -c features.profiles=true -c features.storage.volumes=true
        lxc project set "$LXD_PROJECT" --property description="${PRETTY_REPRO} Isolated Environment ($DEPLOY_ID)"
        
        # Initialize the blank default profile with a root disk and MAAS bridge
        lxc profile device add default root disk path=/ pool="$LXD_POOL" --project "$LXD_PROJECT"

        # Only attach the MAAS bridge to the host profile if non-nested
        if [ "$NESTED" = false ]; then
            lxc profile device add default eth0 nic network="$PRIMARY_BRIDGE" name=eth0 --project "$LXD_PROJECT"
        fi
    else
        echo ""
        echo -e "${BYELLOW}-> LXD Project '${NC}${LXD_PROJECT}${BYELLOW}' already exists, skipping..."
    fi
fi

# ==========================================
# LXD DASHBOARD ACCESS
# ==========================================

echo ""
echo -e "${BYELLOW}-> Opening LXD Web UI...${NC}"
echo ""

LXD_UI_URL="https://localhost:8443/ui/project/${LXD_PROJECT}/instances"

echo -e "${BYELLOW}  LXD Dashboard:${NC} $LXD_UI_URL"
echo ""

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    REMOTE_USER=$(whoami)
    
    echo -e "${BYELLOW}  Remote SSH Session Detected!${NC}"
    echo "  To watch the deployment live from the LXD UI, open a new terminal tab on your host and run:"
    echo ""
    echo -e "${BYELLOW}  Run:${NC} ssh -N -L 8443:localhost:8443 ${REMOTE_USER}@<SERVER_IP>"
    echo -e "${BYELLOW}  URL:${NC} $LXD_UI_URL"
    echo ""
    
    pause_to_continue "Press Enter to launch the VM and begin deployment tracking..."
else
    echo -e "${BYELLOW}  Local session detected. Opening LXD Dashboard...${NC}"
    if command -v xdg-open &> /dev/null; then
        xdg-open "$LXD_UI_URL" > /dev/null 2>&1 &
    fi
fi

# ==========================================
# LAUNCH MAIN VM
# ==========================================

# 1. Launch VM
echo ""
echo -e "${BYELLOW}-> 1. Launching LXD VM '${NC}$VM_NAME${BYELLOW}' (${NC}$IMAGE${BYELLOW}) with CPU: ${NC}$CPU_LIMIT${BYELLOW} cores ; RAM: ${NC}$RAM_LIMIT${BYELLOW} ; DISK: ${NC}$DISK_LIMIT"
echo ""

if ! lxc launch "$IMAGE" "$VM_NAME" --vm --project "$LXD_PROJECT" \
  -c limits.cpu="$CPU_LIMIT" \
  -c limits.memory="$RAM_LIMIT" \
  -d root,size="$DISK_LIMIT" \
  "${LXC_OPTIONAL_ARGS[@]}" \
  -c cloud-init.user-data="$(cat "$CLOUD_INIT")"; then
    echo -e "${BRED}Error: Failed to launch VM. Exiting.${NC}"
    exit 1
fi

lxc config set "$VM_NAME" --project "$LXD_PROJECT"

# ==========================================
# CLEANUP SCRIPT
# ==========================================

# 2. Generate Cleanup Script
CLEANUP_SCRIPT="$SCRIPT_DIR/destroy-${LXD_PROJECT}.sh"

# Write Header
cat << EOF > "$CLEANUP_SCRIPT"
#!/bin/bash
echo ""
echo -e "${BYELLOW}----- Starting Cleanup for LXD Project '$LXD_PROJECT' -----${NC}"
echo ""
EOF

# 1. ONLY purge project if the project is NOT 'default'
if [[ "$LXD_PROJECT" != "default" ]]; then
    cat << EOF >> "$CLEANUP_SCRIPT"
echo -e "${BYELLOW}-> Cleaning up dedicated LXD project:${NC} $LXD_PROJECT"
echo ""
if lxc project list | grep -q "$LXD_PROJECT"; then
    
    # Delete all instances inside the "$LXD_PROJECT" project first
    echo "Stopping and deleting all instances in project '$LXD_PROJECT'..."
    for inst in \$(lxc list --project "$LXD_PROJECT" --format json | jq -r '.[].name'); do
        lxc stop -f --project "$LXD_PROJECT" "\$inst" || true
        sleep 2 # Wait for Ceph/OSD storage locks to release
        lxc delete -f --project "$LXD_PROJECT" "\$inst"
    done
    
    sleep 2 # Buffer to let LXD's database settle before wiping volumes
    
    # Delete all storage volumes inside the "$LXD_PROJECT" project
    echo "Deleting storage volumes in project '$LXD_PROJECT'..."
    for vol in \$(lxc storage volume list "$LXD_POOL" --project "$LXD_PROJECT" --format json | jq -r '.[] | select(.type=="custom") | .name'); do
        lxc storage volume delete "$LXD_POOL" "\$vol" --project "$LXD_PROJECT"
    done
    
    # Delete all images inside the "$LXD_PROJECT" project
    echo "Deleting images in project '$LXD_PROJECT'..."
    for img in \$(lxc image list --project "$LXD_PROJECT" --format json | jq -r '.[].fingerprint'); do
        lxc image delete --project "$LXD_PROJECT" "\$img"
    done
    
    # Switch to default to ensure we aren't "inside" the project we are deleting
    lxc project switch default 2>/dev/null
    lxc project delete "$LXD_PROJECT"
else
    echo "LXD project '$LXD_PROJECT' not found, skipping..."
fi
echo ""
EOF
else
    cat << EOF >> "$CLEANUP_SCRIPT"
echo -e "${BYELLOW}-> Selected 'default' LXD project, skipping... (Leaving instance cleanup to user)${NC}"
echo ""
EOF
fi

# 2. Dynamic Bridge Cleanup
if [ ${#CREATED_BRIDGES[@]} -gt 0 ]; then
    for br in "${CREATED_BRIDGES[@]}"; do
        cat << EOF >> "$CLEANUP_SCRIPT"
echo -e "${BYELLOW}-> Deleting dynamic bridge:${NC} $br"
echo ""
if lxc network show "$br" 2>/dev/null; then
    lxc network delete "$br"
else
    echo "Bridge '$br' not found, skipping..."
fi
echo ""
EOF
    done
fi

# 3. Volatile LXD Certificate Cleanup (Non-nested only)
if [ "$NESTED" = false ]; then
    cat << EOF >> "$CLEANUP_SCRIPT"
echo -e "${BYELLOW}-> Removing LXD trust for volatile certificate:${NC} ${VOLATILE_CERT_NAME}"
echo ""
# Fetch the certificate's fingerprint by matching its common name
FINGERPRINT=\$(lxc config trust list --format json | jq -r '.[] | select(.name=="${VOLATILE_CERT_NAME}") | .fingerprint')

if [ -n "\$FINGERPRINT" ] && [ "\$FINGERPRINT" != "null" ]; then
    lxc config trust remove "\$FINGERPRINT"
else
    echo "Certificate '${VOLATILE_CERT_NAME}' not found in trust store, skipping..."
    echo ""
fi

rm -f "$CERT_DIR/${VOLATILE_CERT_NAME}.crt" "$CERT_DIR/${VOLATILE_CERT_NAME}.key"
EOF
fi

# 4. SSH Multiplex Socket Cleanup & Footer
cat << EOF >> "$CLEANUP_SCRIPT"
if [ -S "$MUX_SOCKET" ]; then
    echo -e "${BYELLOW}-> Cleaning up lingering SSH multiplex socket:${NC} $MUX_SOCKET"
    # Send exit command to the master process via the socket to kill the background daemon
    ssh -O exit -o "ControlPath=$MUX_SOCKET" localhost 2>/dev/null
    rm -f "$MUX_SOCKET"
    echo ""
fi

echo -e "${BYELLOW}-------------- Cleanup Complete --------------${NC}"

# rm -- "\$0" # Self-deletion removed for auditing purposes.
EOF

chmod +x "$CLEANUP_SCRIPT"

# Disable the emergency rollback trap because the persistent cleanup script now exists
CLEANUP_HANDOVER=true

echo ""
echo -e "${BYELLOW}-> 2. Cleanup script created:${NC} $CLEANUP_SCRIPT"

# ==========================================
# ESTABLISH SSH CONNECTION
# ==========================================

# Define SSH options dynamically using SSH Multiplexing (ControlMaster)
if [ -f "$SSH_ID" ]; then
    SSH_MASTER_OPTS=(-i "$SSH_ID" -o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null" -o "ControlMaster=auto" -o "ControlPath=$MUX_SOCKET" -o "ControlPersist=5h")
    SSH_OPTS=(-q -o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null" -o "ControlPath=$MUX_SOCKET")
    SSH_INT_OPTS=(-i "$SSH_ID" -o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null")
else
    SSH_MASTER_OPTS=(-o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null" -o "ControlMaster=auto" -o "ControlPath=$MUX_SOCKET" -o "ControlPersist=5h")
    SSH_OPTS=(-q -o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null" -o "ControlPath=$MUX_SOCKET")
    SSH_INT_OPTS=(-o "StrictHostKeyChecking=no" -o "UserKnownHostsFile=/dev/null")
fi

# 3. Watch for IP Address
echo ""
echo -e "${BYELLOW}-> 3. Obtaining IP Address...${NC}"
echo ""

# Loop until we get an IPv4 address on eth0 (or enp5s0)
IP=""
TIMEOUT=0

while [ -z "$IP" ]; do
    if [ "$TIMEOUT" -ge "$MAX_WAIT" ]; then
        echo -e "${BRED}Error: Timed out waiting for VM to get an IP address.${NC}"
        echo -e "Run '${CLEANUP_SCRIPT}' to clean up the environment."
        exit 1
    fi

    IP=$(lxc list "$VM_NAME" --project "$LXD_PROJECT" --format=json | jq -r '.[0].state.network | to_entries[] | select(.key=="eth0" or .key=="enp5s0") | .value.addresses[] | select(.family=="inet" and .scope=="global") | .address' | head -n 1)

    if [ -z "$IP" ]; then
        sleep 2
        TIMEOUT=$((TIMEOUT + 2))
    fi
done

echo "Target IP: $IP"
echo ""

lxc list --project "$LXD_PROJECT"

# 4. Wait for SSH to become available and establish Master Socket
echo ""
echo -e "${BYELLOW}-> 4. Waiting for VM SSH service to start...${NC}"
echo ""

TIMEOUT=0

# Use the LXD API to check the VM's authorized_keys
until lxc exec "$VM_NAME" --project "$LXD_PROJECT" -- test -s "/home/$SYS_USER/.ssh/authorized_keys" 2>/dev/null; do
    if [ "$TIMEOUT" -ge "$MAX_WAIT" ]; then
        echo ""
        echo -e "${BRED}Error: Timed out waiting for cloud-init to inject SSH keys on $VM_NAME.${NC}"
        echo -e "Run '${CLEANUP_SCRIPT}' to clean up the environment."
        exit 1
    fi
    sleep 2
    TIMEOUT=$((TIMEOUT + 2))
done

sleep 3 # Small 3-second buffer to ensure the SSH daemon has fully bound to port 22

echo "Establishing master SSH connection (Enter key passphrase if prompted)..."

if ! ssh "${SSH_MASTER_OPTS[@]}" "${SYS_USER}@$IP" exit; then
    echo -e "${BRED}Error: Failed to establish SSH connection. Check your SSH keys or passphrase.${NC}"
    echo -e "Run '${CLEANUP_SCRIPT}' to clean up the environment."
    exit 1
fi

echo "Secure SSH multiplex tunnel established!"

# ==========================================
# LOG TAILING + JUJU STATUS
# ==========================================

# 5. Wait for cloud-init to finish and tail logs and then Juju watch
echo ""
echo -e "${BYELLOW}-> 5. Connecting to live cloud-init logs... (will switch to Juju status)${NC}"
echo ""

CLOUD_INIT_LOG_LINES=7 # Lines to show while Juju status watch
PHASE="LOG_TAIL" # Phase options: LOG_TAIL, JUJU_WATCH, DONE
CURSOR_TOP='\033[H'
CLEAR_REST='\033[J'
CLR_EOL=$'\033[K'

while [ "$PHASE" != "DONE" ]; do

    # PHASE A: LOG TAILING
    if [ "$PHASE" == "LOG_TAIL" ]; then
        
        # Build the sed command dynamically based on whether a Juju trigger exists, quit 'q' if we see the Trigger Message OR "finished at"
        if [ -n "$JUJU_TRIGGER_MSG" ]; then
            ssh "${SSH_OPTS[@]}" -t "${SYS_USER}@$IP" "tail -f /var/log/cloud-init-output.log 2>/dev/null | sed '/$JUJU_TRIGGER_MSG/ q; /finished at/ q'"
        else
            ssh "${SSH_OPTS[@]}" -t "${SYS_USER}@$IP" "tail -f /var/log/cloud-init-output.log 2>/dev/null | sed '/finished at/ q'"
        fi
        
        EXIT_CODE=$?

        if [ $EXIT_CODE -eq 0 ]; then
            # Success! The 'sed' command found the Juju model deploy start and quit cleanly.
            STATUS_CHECK=$(ssh "${SSH_OPTS[@]}" "${SYS_USER}@$IP" "cloud-init status" 2>/dev/null)
            
            if [[ "$STATUS_CHECK" == *"status: error"* ]]; then
                echo ""
                echo -e "${BRED}Error: cloud-init crashed during payload execution! Check the logs above.${NC}${CLR_EOL}"
                echo -e "Run '${CLEANUP_SCRIPT}' to clean up the environment."
                exit 1
            elif [[ "$STATUS_CHECK" == *"status: done"* ]]; then
                echo ""
                echo -e "${BYELLOW}cloud-init finished successfully! ${NC}${CLR_EOL}"
                PHASE="DONE"
            else
                echo ""
                echo -e "${BYELLOW}Juju Deployment Trigger Detected. Switching to Watch Mode...${NC}${CLR_EOL}"
                sleep 2
                PHASE="JUJU_WATCH"
            fi

        elif [ $EXIT_CODE -eq 255 ]; then
            # 255 = SSH died (Connection Refused / Network Down / Rebooting)
            echo -ne "${BYELLOW}Connection lost (Rebooting?) retrying...${NC}${CLR_EOL}\r"
            sleep 3
        else
            # Other errors (file not found yet, etc)
            echo -ne "${BYELLOW}Waiting for log file creation...${NC}${CLR_EOL}\r"
            sleep 2
        fi
    fi

    # PHASE B: JUJU WATCH
    if [ "$PHASE" == "JUJU_WATCH" ]; then

        # This command attempts to query the models in reverse order of creation
        JUJU_CMD="juju status -m openstack --color 2>/dev/null || juju status -m openstack-machines --color 2>/dev/null || juju status -m openstack-infra --color 2>/dev/null || juju status -m controller --color 2>/dev/null || echo 'Waiting for Juju models to initialize...'"

        # Capture both status commands first
        # shellcheck disable=SC2029
        JUJU_OUTPUT=$(ssh "${SSH_OPTS[@]}" "${SYS_USER}@$IP" "$JUJU_CMD" 2>/dev/null)
        # shellcheck disable=SC2029
        LOG_OUTPUT=$(ssh "${SSH_OPTS[@]}" "${SYS_USER}@$IP" "tail -n $CLOUD_INIT_LOG_LINES /var/log/cloud-init-output.log | sed 's/\r$//' | sed 's/.*\r//' | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g'" 2>/dev/null)
        SSH_EXIT=$?
        CI_STATUS=$(ssh "${SSH_OPTS[@]}" "${SYS_USER}@$IP" "cloud-init status" 2>/dev/null)

        # Check if we should stop (Is cloud-init done?)
        if [[ "$CI_STATUS" == *"status: error"* ]]; then
            echo ""
            echo -e "${BRED}Error: cloud-init crashed during deployment! Check the logs above.${NC}${CLR_EOL}"
            echo -e "Run '${CLEANUP_SCRIPT}' to clean up the environment."
            exit 1
        elif [[ "$CI_STATUS" == *"status: done"* ]]; then
            # Print the final status one last time cleanly
            echo -e "${CURSOR_TOP}${BYELLOW}-> 5. Juju Deployment Status (Finalizing...)${NC}${CLR_EOL}"
            echo -e "Target IP: $IP | Updated: $(date +%T)${CLR_EOL}"
            echo -e "${BYELLOW}-------------------------------------------------------${NC}${CLR_EOL}"
            echo -e "$JUJU_OUTPUT" | sed "s/$/${CLR_EOL}/"
            echo -e "${CLEAR_REST}" # Clean up bottom
            echo ""
            echo -e "${BYELLOW}cloud-init finished successfully!${NC}"
            PHASE="DONE"
            break
        fi

        # Repaint screen
        if [ $SSH_EXIT -eq 0 ]; then
            # Move cursor to top (0,0) -> Print Data -> Clear remaining junk at bottom
            echo -ne "${CURSOR_TOP}"

            # Header
            echo -e "${BYELLOW}-> 5. Juju Deployment Status (cloud-init is running...)${NC}${CLR_EOL}"
            echo -e "Target IP: $IP | Updated: $(date +%T)${CLR_EOL}"

            # Tail $CLOUD_INIT_LOG_LINES lines of cloud-init logs
            echo -e "${BYELLOW}---------------- Latest cloud-init Logs ----------------${NC}${CLR_EOL}"
            # Print logs, ensuring we wipe the end of the line for every log entry
            if [ -n "$LOG_OUTPUT" ]; then
                echo -e "$LOG_OUTPUT" | sed "s/$/${CLR_EOL}/"
            else
                echo -e "(Waiting for logs...)${CLR_EOL}"
            fi

            # Juju watch
            echo -e "${BYELLOW}--------------------- Juju Status ----------------------${NC}${CLR_EOL}"

            # Get terminal height (default to 64 if it fails)
            TERM_HEIGHT=$(tput lines 2>/dev/null || echo 64)
            
            # Reserve lines for cloud-init logs + header (6)
            MAX_JUJU_LINES=$(( TERM_HEIGHT - ( 6 + CLOUD_INIT_LOG_LINES )))
            if [ "$MAX_JUJU_LINES" -lt 5 ]; then MAX_JUJU_LINES=5; fi # Fallback for tiny windows
            
            JUJU_LINE_COUNT=$(echo "$JUJU_OUTPUT" | wc -l)

            # Print Juju output: Truncate if it exceeds available terminal lines
            if [ "$JUJU_LINE_COUNT" -gt "$MAX_JUJU_LINES" ]; then
                HIDDEN_LINES=$(( JUJU_LINE_COUNT - MAX_JUJU_LINES ))
                echo -e "$JUJU_OUTPUT" | head -n "$MAX_JUJU_LINES" | sed "s/$/${CLR_EOL}/"
                echo -e "... [ Output truncated by $HIDDEN_LINES lines to fit terminal. Maximize window to see more! ] ...${CLR_EOL}"
            else
                echo -e "$JUJU_OUTPUT" | sed "s/$/${CLR_EOL}/"
            fi
            
            # Clear whatever is left at the very bottom of the screen (in case list got shorter)
            echo -ne "${CLEAR_REST}"
        else
            # If SSH fails, just print a warning on top, don't wipe screen
            echo -ne "${CURSOR_TOP}${BYELLOW}Connection lost. Reconnecting...${NC}${CLR_EOL}\r"
        fi

        # Standard refresh rate
        sleep 3
    fi
done
# Force cursor to reappear
echo -e "\033[?25h"

# ==========================================
# POST_DEPLOYMENT ACTIONS
# ==========================================

# 6. MAAS Dashboard Access (SSH-Aware)
echo ""
echo -e "${BYELLOW}-> 6. Opening MAAS Dashboard...${NC}"
echo ""

MAAS_UI_URL="http://$IP:5240/MAAS/"

echo -e "${BYELLOW}  MAAS Dashboard:${NC} $MAAS_UI_URL"
echo ""

if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    REMOTE_USER=$(whoami)
    
    echo -e "${BYELLOW}  Remote SSH Session Detected!${NC}"
    echo "  To access the MAAS dashboard locally, open a new terminal tab on your host and run:"
    echo ""
    echo -e "${BYELLOW}  Run:${NC} ssh -N -L 5240:$IP:5240 ${REMOTE_USER}@<SERVER_IP>"
    echo -e "${BYELLOW}  URL:${NC} http://localhost:5240/MAAS/"
    echo ""
    
    pause_to_continue "Press Enter to drop into the final interactive shell..."
else
    echo -e "${BYELLOW}  Local session detected. Opening MAAS Dashboard...${NC}"
    if command -v xdg-open &> /dev/null; then
        xdg-open "$MAAS_UI_URL" > /dev/null 2>&1 &
    fi
fi

# ==========================================
# FINAL SSH SHELL
# ==========================================

# 7. Final Interactive Shell
echo ""
echo -e "${BYELLOW}-> 7. Dropping into interactive shell...${NC}"
echo ""

# Close the SSH Multiplex Socket
echo "  Closing background SSH multiplex socket..."
ssh -O exit -o "ControlPath=$MUX_SOCKET" "${SYS_USER}@$IP" 2>/dev/null
rm -f "$MUX_SOCKET"
echo ""

# shellcheck disable=SC2029
ssh "${SSH_INT_OPTS[@]}" "${SYS_USER}@$IP"

# ==========================================
# DONE
# ==========================================

